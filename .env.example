# Tatá House — variáveis de ambiente
# Copie este arquivo para .env.local (no seu computador) ou configure os mesmos
# nomes na Vercel (Settings → Environment Variables).
#
# O Supabase é OPCIONAL: sem estas variáveis, o app funciona 100% em localStorage.

# URL do projeto Supabase (Supabase → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave pública do Supabase — aceita a "anon" (eyJ...) ou a "publishable" (sb_publishable_...)
# (Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-publica

# Opcional: separa os dados por unidade/loja (default: tata-house)
# NEXT_PUBLIC_TATA_ESPACO=tata-house
